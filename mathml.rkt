(define lp (Mo "("))
(define rp (Mo ")"))
(define lp0 '(mo ((stretchy "false")) "("))
(define rp0 '(mo ((stretchy "false")) ")"))
(define lb (Mo "["))
(define rb (Mo "]"))
(define lb0 '(mo ((stretchy "false")) "["))
(define rb0 '(mo ((stretchy "false")) "]"))
(define lc (Mo "{"))
(define rc (Mo "}"))
(define lv (Mo "|"))
(define rv (Mo "|"))
(define (pare x)
  (Mrow lp x rp))
(define (par0 x)
  (Mrow lp0 x rp0))
(define (brac x)
  (Mrow lb x rb))
(define (bra0 x)
  (Mrow lb0 x rb0))
(define (curb x)
  (Mrow lc x rc))
(define (vert x)
  (Mrow lv x rv))

(define (seq . x*)
  (cond
    ((null? x*) $)
    ((null? (cdr x*)) (car x*))
    (else
     (let iter ((x (car x*)) (x* (cdr x*)) (r '()))
       (if (null? x*)
           (cons 'mrow (reverse (cons x r)))
           (iter (car x*)
                 (cdr x*)
                 (cons cm (cons x r))))))))

(define (tup . x*)
  (pare (apply seq x*)))
(define (tu0 . x*)
  (par0 (apply seq x*)))
(define (lis . x*)
  (brac (apply seq x*)))
(define (li0 . x*)
  (bra0 (apply seq x*)))

(define (sum u o e)
  (Mrow (Munderover '(mo "&sum;") u o) e))
(define (prod u o e)
  (Mrow (Munderover '(mo "&prod;") u o) e))

(define (mtab l)
  (cons 'mtable
        (map (lambda (r)
               (cons 'mtr (map Mtd r)))
             l)))
(define (choice l)
  (Mrow lc (mtab l)))
(define (mat l)
  (brac (mtab l)))
(define (det l)
  (vert (mtab l)))
(define (deriv x y . z*)
  (mtab
   (cons (list x := y)
         (map (lambda (z)
                (list $ := z))
              z*))))

(define (^ a b)
  (Msup a b))
(define (_ a b)
  (Msub a b))
(define (:sqr x)
  (^ x :2))
(define (:cub x)
  (^ x :3))

(define (inv x)
  (Mfrac :1 x))

(define (fact n)
  (Mrow n '(mo "!")))

(define (comb a b)
  (pare (Mfrac0 a b)))

(define (lim x c e)
  (Mrow (Munder '(mo "lim")
                (Mrow x -> c))
        e))

