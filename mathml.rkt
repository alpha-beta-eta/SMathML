    (Mtr (Mtd $) (Mtd ->)
         (Mtd #:attr* '((columnalign "left")) e)))
  (define line*
    (if (null? z*)
        '()
        (let iter ((-> (car z*)) (e (cadr z*)) (z* (cddr z*)) (r '()))
          (if (null? z*)
              (reverse (cons (make-line -> e) r))
              (iter (car z*) (cadr z*) (cddr z*)
                    (cons (make-line -> e) r))))))
